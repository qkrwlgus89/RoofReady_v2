# OpenAI
OPENAI_API_KEY=sk-...

# 공공데이터포털 API 키 (data.go.kr에서 발급)
DATA_GO_KR_API_KEY=...

# 저장소 경로 (기본값 사용 가능)
CHROMA_DB_PATH=./data/chroma_db
PDF_CACHE_PATH=./data/pdfs

# 스케줄러 수집 주기 (시간 단위, 기본 6시간)
SCHEDULER_INTERVAL_HOURS=6

# 모델 설정
EMBEDDING_MODEL=text-embedding-3-small
LLM_MODEL=gpt-4o
TOP_K_RETRIEVAL=8

# 로그 레벨 (DEBUG / INFO / WARNING / ERROR)
LOG_LEVEL=INFO
